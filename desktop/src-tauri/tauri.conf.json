{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Spacebot",
  "version": "0.1.0",
  "identifier": "sh.spacebot.desktop",
  "build": {
    "devUrl": "http://localhost:19840",
    "frontendDist": "http://localhost:19898"
  },
  "app": {
    "macOSPrivateApi": true,
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Spacebot",
        "hiddenTitle": true,
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": true,
        "transparent": true,
        "visible": false,
        "titleBarStyle": "Overlay",
        "backgroundColor": [0, 0, 0, 0],
        "windowEffects": {
          "effects": ["sidebar"],
          "state": "followsWindowActiveState",
          "radius": 9
        }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "resources": {
      "gen/icon/**/*": "./"
    },
    "macOS": {
      "minimumSystemVersion": "11.0",
      "infoPlist": "Info.plist"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
